# --- Discord credentials ---
DISCORD_TOKEN=your_discord_bot_token
# Channel where the bot proactively posts new alerts (bonus feature)
DISCORD_ALERT_CHANNEL_ID=your_channel_id

# --- Shared backend (single source of truth) ---
BACKEND_API_URL=http://localhost:5000

# --- AI (Groq) ---
# PREFERRED: put GROQ_API_KEY in backend/.env — the bot uses the backend's AI
# (/api/ai/*) automatically. A key here is only a LOCAL FALLBACK.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
