# Backend configuration
PORT=5000
CLIENT_URL=http://localhost:5173

# --- AI (Groq) — powers the website chatbot AND the Discord bot's friendly
# replies. THE KEY GOES HERE (one place). Free key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override the AI's persona (one line). Strict topic rules are ALWAYS
# enforced on top: the bot only discusses this office's electricity/devices/
# usage/waste/alerts and refuses off-topic questions.
AI_SYSTEM_PROMPT=

# Shorten the "all devices ON for 2 hours" alert for demos (minutes, default 120)
ALL_ON_ALERT_MINUTES=120

# Occupancy simulation speed multiplier (1 = realistic minutes-scale;
# 10 = everything happens 10x faster — handy for demos)
SIM_SPEED=1

# ChromaDB server for the waste-event RAG store (optional — falls back to a
# local JSON log if unreachable). Start one with:
#   pip install chromadb && chroma run --path ./chroma-data
CHROMA_URL=http://localhost:8000
